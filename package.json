{
  "name": "snapscroll",
  "version": "1.0.0",
  "description": "Snipaste-like screenshot tool with scrolling long capture",
  "main": "./out/main/index.js",
  "author": "personal",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "start:app": "electron .",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "@nut-tree-fork/nut-js": "^4.2.6",
    "jimp": "^1.6.0",
    "koffi": "^3.1.1",
    "screenshot-desktop": "^1.15.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^35.7.5",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.0.0",
    "png-to-ico": "3.0.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.8.2",
    "vite": "^6.2.0"
  },
  "build": {
    "appId": "com.personal.snapscroll",
    "productName": "截图助手",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources",
        "to": "resources",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "icon": "resources/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "icon": "resources/icon.png",
      "target": [
        "dmg"
      ]
    },
    "linux": {
      "icon": "resources/icon.png",
      "target": [
        "AppImage"
      ]
    }
  }
}
